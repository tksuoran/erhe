{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "ERHE_collections.schema.json",
    "title": "ERHE_collections glTF asset-root extension",
    "type": "object",
    "properties": {
        "collections": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name":  {"type": "string"},
                    "items": {"type": "array", "items": {"type": "integer", "minimum": 0}}
                },
                "required": ["name", "items"]
            }
        }
    },
    "required": ["collections"]
}
