{
    "_version": 1,
    "developer": {
        "_version": 1,
        "enable": true
    },
    "graphics": {
        "_version": 1,
        "initial_clear": true,
        "post_processing": true,
        "force_bindless_textures_off": false,
        "force_no_persistent_buffers": false,
        "force_no_direct_state_access": false,
        "force_no_clip_control": false,
        "force_emulate_multi_draw_indirect": false,
        "force_no_compute_shader": false,
        "force_gl_version": 0,
        "force_glsl_version": 0,
        "renderdoc_capture_support": false,
        "shader_monitor_enabled": true
    },
    "mesh_memory": {
        "_version": 1,
        "vertex_buffer_size": 1024,
        "index_buffer_size": 256
    },
    "renderer": {
        "_version": 1,
        "max_material_count": 1000,
        "max_light_count": 32,
        "max_camera_count": 256,
        "max_joint_count": 1000,
        "max_primitive_count": 6000,
        "max_draw_count": 6000
    },
    "shader_monitor": {
        "_version": 1,
        "enabled": true
    },
    "text_renderer": {
        "_version": 1,
        "enabled": true,
        "font_size": 14
    },
    "threading": {
        "_version": 1,
        "thread_count": 8
    },
    "window": {
        "_version": 1,
        "show": true,
        "fullscreen": false,
        "use_transparency": false,
        "gl_major": 4,
        "gl_minor": 6,
        "size": [1920,1080],
        "color_bit_depth": 8,
        "high_pixel_density": true,
        "use_finish": false,
        "use_sleep": false,
        "sleep_margin": 0,
        "swap_interval": 0,
        "enable_joystick": true
    }
}
